rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserExists() {
      return signedIn()
          && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentRole() {
      return currentUserExists()
          ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
          : null;
    }

    function isAdmin() {
      return currentRole() == 'ADMIN';
    }

    function isManager() {
      return currentRole() == 'MANAGER';
    }

    function isPatient() {
      return currentRole() == 'PATIENT';
    }

    function isGuardian() {
      return currentRole() == 'GUARDIAN';
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isClientCreatableRole(role) {
      return role == 'PATIENT'
          || role == 'GUARDIAN'
          || role == 'MANAGER';
    }

    function appointmentExists(appointmentRequestId) {
      return exists(
          /databases/$(database)/documents/appointmentRequests/$(appointmentRequestId)
      );
    }

    function appointmentDoc(appointmentRequestId) {
      return get(
          /databases/$(database)/documents/appointmentRequests/$(appointmentRequestId)
      );
    }

    function appointmentDocAfter(appointmentRequestId) {
      return getAfter(
          /databases/$(database)/documents/appointmentRequests/$(appointmentRequestId)
      );
    }

    function isAppointmentParticipant(appointmentRequestId) {
      return signedIn()
          && appointmentExists(appointmentRequestId)
          && (
            isAdmin()
            || appointmentDoc(appointmentRequestId).data.patientUserId == request.auth.uid
            || appointmentDoc(appointmentRequestId).data.guardianUserId == request.auth.uid
            || appointmentDoc(appointmentRequestId).data.managerUserId == request.auth.uid
          );
    }

    function sessionExists(sessionId) {
      return exists(/databases/$(database)/documents/companionSessions/$(sessionId));
    }

    function sessionDoc(sessionId) {
      return get(/databases/$(database)/documents/companionSessions/$(sessionId));
    }

    function isSessionParticipant(sessionId) {
      return signedIn()
          && sessionExists(sessionId)
          && (
            isAdmin()
            || sessionDoc(sessionId).data.managerUserId == request.auth.uid
            || sessionDoc(sessionId).data.patientUserId == request.auth.uid
            || sessionDoc(sessionId).data.guardianUserId == request.auth.uid
          );
    }

    function canGetUser(userId) {
      return isSelf(userId)
          || isAdmin();
    }

    function canReadAppointmentRequest() {
      return signedIn()
          && (
            isAdmin()
            || resource.data.patientUserId == request.auth.uid
            || resource.data.guardianUserId == request.auth.uid
            || resource.data.managerUserId == request.auth.uid
          );
    }

    function canReadCompanionSession() {
      return signedIn()
          && (
            isAdmin()
            || resource.data.managerUserId == request.auth.uid
            || resource.data.patientUserId == request.auth.uid
            || resource.data.guardianUserId == request.auth.uid
          );
    }

    function canReadSessionReport() {
      return signedIn()
          && (
            isAdmin()
            || (
              resource.data.sessionId is string
              && isSessionParticipant(resource.data.sessionId)
            )
          );
    }

    function createdOnly(allowedKeys) {
      return request.resource.data.keys().hasOnly(allowedKeys);
    }

    function affectedOnly(allowedKeys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedKeys);
    }

    function affectedAny(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(keys);
    }

    function managerDocumentStatusUpdateIsSafe() {
      return !affectedAny(['managerDocumentStatus'])
          || (
            request.resource.data.keys().hasAll(['managerDocumentStatus'])
            && request.resource.data.managerDocumentStatus != 'APPROVED'
            && request.resource.data.managerDocumentStatus != 'REJECTED'
          );
    }

    function isClientRole() {
      return isPatient() || isGuardian();
    }

    function isAppointmentRequestOwner(data) {
      return signedIn()
          && (
            (isPatient() && data.patientUserId == request.auth.uid)
            || (isGuardian() && data.guardianUserId == request.auth.uid)
          );
    }

    function appointmentRequestClientWritableFields() {
      return [
        'patientUserId',
        'patientName',
        'patientPhone',
        'patientEmail',
        'guardianUserId',
        'guardianName',
        'guardianPhone',
        'guardianEmail',
        'hospitalName',
        'departmentName',
        'appointmentAt',
        'meetingPlace',
        'specialNotes',
        'patientConditionSummary',
        'medicationSummary',
        'mobilitySupportCode',
        'tripTypeCode',
        'managerGenderPreferenceCode',
        'paymentMethodCode',
        'couponCode',
        'basePrice',
        'optionSurchargePrice',
        'couponDiscountPrice',
        'finalPrice',
        'paymentStatusCode',
        'paymentApprovalCode',
        'paymentApprovedAt',
        'paymentProviderLabel',
        'appointmentAtEpochMillis',
        'appointmentDateKey',
        'reminderStages',
        'status',
        'managerUserId',
        'requesterUserId',
        'requesterRole',
        'requesterName',
        'requesterPhone',
        'createdAt',
        'updatedAt'
      ];
    }

    function canClientCreateAppointmentRequest() {
      return isClientRole()
          && createdOnly(appointmentRequestClientWritableFields())
          && request.resource.data.keys().hasAll([
            'status',
            'managerUserId',
            'requesterUserId',
            'requesterRole',
            'createdAt'
          ])
          && request.resource.data.status == 'REQUESTED'
          && request.resource.data.managerUserId == null
          && request.resource.data.requesterUserId == request.auth.uid
          && request.resource.data.requesterRole == currentRole()
          && isAppointmentRequestOwner(request.resource.data);
    }

    function canClientEditAppointmentRequest() {
      return isClientRole()
          && isAppointmentRequestOwner(resource.data)
          && isAppointmentRequestOwner(request.resource.data)
          && resource.data.status == 'REQUESTED'
          && request.resource.data.status == 'REQUESTED'
          && request.resource.data.managerUserId == null
          && request.resource.data.requesterUserId == request.auth.uid
          && request.resource.data.requesterRole == currentRole()
          && affectedOnly(appointmentRequestClientWritableFields());
    }

    function canClientCancelAppointmentRequest() {
      return isClientRole()
          && isAppointmentRequestOwner(resource.data)
          && resource.data.status in ['REQUESTED', 'MATCHED']
          && request.resource.data.status == 'CANCELED'
          && affectedOnly(['status', 'updatedAt']);
    }

    function canManagerUpdateAppointmentStatus() {
      return isManager()
          && resource.data.managerUserId == request.auth.uid
          && resource.data.status in ['MATCHED', 'IN_PROGRESS']
          && request.resource.data.status in ['IN_PROGRESS', 'COMPLETED']
          && affectedOnly(['status']);
    }

    function companionSessionCreateFields() {
      return [
        'appointmentRequestId',
        'patientUserId',
        'guardianUserId',
        'managerUserId',
        'currentStepOrder',
        'currentStatus',
        'guardianUpdate',
        'locationSummary',
        'fieldPhotoNote',
        'medicationNote',
        'pharmacySummary',
        'prescriptionCollected',
        'pharmacyCompleted',
        'medicationGuidanceCompleted',
        'liveLocationSharingActive',
        'sharedLocationHistory',
        'createdAt',
        'updatedAt'
      ];
    }

    function companionSessionManagerWritableFields() {
      return [
        'currentStepOrder',
        'currentStatus',
        'guardianUpdate',
        'locationSummary',
        'fieldPhotoNote',
        'medicationNote',
        'pharmacySummary',
        'prescriptionCollected',
        'pharmacyCompleted',
        'medicationGuidanceCompleted',
        'sharedLatitude',
        'sharedLongitude',
        'sharedLocationUpdatedAt',
        'sharedLocationHistory',
        'liveLocationSharingActive',
        'liveLocationSharingStartedAt',
        'chatMessages',
        'managerChatReadAt',
        'locationAlertStage',
        'locationAlertSentAt',
        'updatedAt'
      ];
    }

    function canCreateCompanionSession() {
      return signedIn()
          && createdOnly(companionSessionCreateFields())
          && request.resource.data.keys().hasAll([
            'appointmentRequestId',
            'patientUserId',
            'guardianUserId',
            'managerUserId',
            'currentStatus',
            'liveLocationSharingActive'
          ])
          && request.resource.data.currentStatus == 'READY'
          && request.resource.data.liveLocationSharingActive == false
          && appointmentExists(request.resource.data.appointmentRequestId)
          && request.resource.data.patientUserId
              == appointmentDocAfter(request.resource.data.appointmentRequestId).data.patientUserId
          && request.resource.data.guardianUserId
              == appointmentDocAfter(request.resource.data.appointmentRequestId).data.guardianUserId
          && request.resource.data.managerUserId
              == appointmentDocAfter(request.resource.data.appointmentRequestId).data.managerUserId
          && (
            isAdmin()
            || (
              isManager()
              && request.resource.data.managerUserId == request.auth.uid
            )
          );
    }

    function canManagerUpdateCompanionSession() {
      return isManager()
          && resource.data.managerUserId == request.auth.uid
          && affectedOnly(companionSessionManagerWritableFields())
          && (
            !affectedAny(['currentStatus'])
            || request.resource.data.currentStatus in ['READY', 'IN_PROGRESS', 'COMPLETED']
          );
    }

    function canClientCancelCompanionSession() {
      return isClientRole()
          && (
            resource.data.patientUserId == request.auth.uid
            || resource.data.guardianUserId == request.auth.uid
          )
          && request.resource.data.currentStatus == 'CANCELED'
          && request.resource.data.liveLocationSharingActive == false
          && affectedOnly([
            'currentStatus',
            'liveLocationSharingActive',
            'liveLocationSharingStartedAt',
            'updatedAt'
          ]);
    }

    function canPatientUpdateCompanionChat() {
      return isPatient()
          && resource.data.patientUserId == request.auth.uid
          && affectedOnly(['chatMessages', 'patientChatReadAt', 'updatedAt']);
    }

    function canGuardianUpdateCompanionChat() {
      return isGuardian()
          && resource.data.guardianUserId == request.auth.uid
          && affectedOnly(['chatMessages', 'guardianChatReadAt', 'updatedAt']);
    }

    function appointmentFollowUpClientWritableFields() {
      return [
        'requestId',
        'reviewRatingCode',
        'reviewSavedByUserId',
        'reviewSavedAt',
        'settlementFollowUpStatus',
        'settlementFollowUpNote',
        'settlementFollowUpSavedByUserId',
        'settlementFollowUpSavedAt',
        'supportEscalationStatus',
        'supportEscalatedByUserId',
        'supportEscalatedAt',
        'updatedAt'
      ];
    }

    function followUpCreateActorFieldsAreValid() {
      return (
            !request.resource.data.keys().hasAny(['reviewSavedByUserId'])
            || request.resource.data.reviewSavedByUserId == request.auth.uid
          )
          && (
            !request.resource.data.keys().hasAny(['settlementFollowUpSavedByUserId'])
            || request.resource.data.settlementFollowUpSavedByUserId == request.auth.uid
          )
          && (
            !request.resource.data.keys().hasAny(['supportEscalatedByUserId'])
            || request.resource.data.supportEscalatedByUserId == request.auth.uid
          );
    }

    function followUpUpdateActorFieldsAreValid() {
      return (
            !affectedAny(['reviewSavedByUserId'])
            || request.resource.data.reviewSavedByUserId == request.auth.uid
          )
          && (
            !affectedAny(['settlementFollowUpSavedByUserId'])
            || request.resource.data.settlementFollowUpSavedByUserId == request.auth.uid
          )
          && (
            !affectedAny(['supportEscalatedByUserId'])
            || request.resource.data.supportEscalatedByUserId == request.auth.uid
          );
    }

    function canClientCreateAppointmentFollowUp(appointmentRequestId) {
      return isClientRole()
          && isAppointmentParticipant(appointmentRequestId)
          && createdOnly(appointmentFollowUpClientWritableFields())
          && request.resource.data.requestId == appointmentRequestId
          && followUpCreateActorFieldsAreValid();
    }

    function canClientUpdateAppointmentFollowUp(appointmentRequestId) {
      return isClientRole()
          && isAppointmentParticipant(appointmentRequestId)
          && affectedOnly(appointmentFollowUpClientWritableFields())
          && request.resource.data.requestId == appointmentRequestId
          && followUpUpdateActorFieldsAreValid();
    }

    match /users/{userId} {
      // 사용자 문서는 본인과 관리자만 직접 읽고, 교차 프로필 참조는 Functions 중계를 사용한다.
      allow get: if canGetUser(userId);
      allow list: if isAdmin();
      allow create: if isSelf(userId)
          && isClientCreatableRole(request.resource.data.role);
      allow update: if isAdmin()
          || (
            isSelf(userId)
            && request.resource.data.role == resource.data.role
            && managerDocumentStatusUpdateIsSafe()
          );
      allow delete: if isAdmin();
    }

    match /appointmentRequests/{appointmentRequestId} {
      // 매니저 대시보드와 후속 화면에서 참조가 많아 개발 중에는 로그인 사용자 읽기를 허용한다.
      allow read: if canReadAppointmentRequest();

      // 신규 신청은 환자, 보호자, 관리자만 생성할 수 있다.
      allow create: if isAdmin()
          || canClientCreateAppointmentRequest();

      // 매칭과 상태 변경은 배정된 매니저 또는 관리자가 담당한다.
      allow update: if isAdmin()
          || canClientEditAppointmentRequest()
          || canClientCancelAppointmentRequest()
          || canManagerUpdateAppointmentStatus();
      allow delete: if isAdmin();
    }

    match /companionSessions/{sessionId} {
      // 세션 조회는 쿼리 기반으로 이루어져 개발 중에는 로그인 사용자 읽기를 허용한다.
      allow read: if canReadCompanionSession();

      // 세션 생성과 수정은 배정된 매니저 또는 관리자가 수행한다.
      allow create: if canCreateCompanionSession();
      allow update: if isAdmin()
          || canManagerUpdateCompanionSession()
          || canClientCancelCompanionSession()
          || canPatientUpdateCompanionChat()
          || canGuardianUpdateCompanionChat();
      allow delete: if isAdmin();
    }

    match /hospitalGuides/{guideId} {
      // 병원 가이드는 로그인 사용자라면 읽을 수 있고, 수정은 관리자만 가능하다.
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /sessionReports/{reportId} {
      // 리포트도 화면 결합도가 높아 개발 단계에서는 로그인 사용자 읽기를 허용한다.
      allow read: if canReadSessionReport();

      // 최종 리포트 작성은 배정된 매니저 또는 관리자만 가능하다.
      allow create, update: if isAdmin()
          || (isManager() && isSessionParticipant(request.resource.data.sessionId));
      allow delete: if isAdmin();
    }

    match /appointmentFollowUps/{appointmentRequestId} {
      allow read: if isAdmin() || isAppointmentParticipant(appointmentRequestId);
      allow create: if isAdmin() || canClientCreateAppointmentFollowUp(appointmentRequestId);
      allow update: if isAdmin() || canClientUpdateAppointmentFollowUp(appointmentRequestId);
      allow delete: if isAdmin();
    }

    match /supportInquiries/{inquiryId} {
      allow read: if isAdmin()
          || (isManager() && resource.data.managerUserId == request.auth.uid);
      allow create: if isManager()
          && request.resource.data.managerUserId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /clientSupportRequests/{supportRequestId} {
      allow read: if isAdmin()
          || (
            signedIn()
            && resource.data.userId == request.auth.uid
          );
      allow create: if (isPatient() || isGuardian())
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.userRole == currentRole();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /adminSettlementRecords/{appointmentRequestId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /adminEmergencyIssues/{appointmentRequestId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /adminActionNotifications/{notificationId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /adminAuditLogs/{auditLogId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /adminActionDeliveries/{deliveryId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /adminActionDeliveryJobs/{jobId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /appointmentReminderJobs/{jobId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}
