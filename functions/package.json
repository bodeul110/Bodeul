{
  "name": "bodeul-functions",
  "private": true,
  "engines": {
    "node": "22"
  },
  "main": "index.js",
  "scripts": {
    "deploy": "firebase deploy --only functions",
    "serve": "firebase emulators:start --only functions",
    "logs": "firebase functions:log",
    "retention:dry-run": "node scripts/run-retention.js --dry-run",
    "retention:apply": "node scripts/run-retention.js --apply",
    "test": "node --test test/*.test.js"
  },
  "dependencies": {
    "firebase-admin": "13.10.0",
    "firebase-functions": "7.3.0",
    "postgres": "3.4.9"
  },
  "overrides": {
    "gaxios": {
      "uuid": "11.1.1"
    },
    "google-gax": {
      "uuid": "11.1.1"
    },
    "teeny-request": {
      "uuid": "11.1.1"
    }
  }
}
