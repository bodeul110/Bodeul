<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Bodeul" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/bodeul_primary</item>
        <item name="colorPrimaryVariant">@color/bodeul_primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/bodeul_secondary</item>
        <item name="colorSecondaryVariant">@color/bodeul_secondary</item>
        <item name="colorOnSecondary">@color/bodeul_text_primary</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="android:windowBackground">@color/bodeul_background</item>
    </style>

    <style name="BodeulHomeButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">12dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="backgroundTint">@color/bodeul_primary</item>
        <item name="cornerRadius">18dp</item>
    </style>
</resources>
