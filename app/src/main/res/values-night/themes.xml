<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Bodeul" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/bodeul_primary</item>
        <item name="colorPrimaryVariant">@color/bodeul_primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/bodeul_secondary</item>
        <item name="colorSecondaryVariant">@color/bodeul_secondary</item>
        <item name="colorOnSecondary">@color/bodeul_text_primary</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="android:windowBackground">@color/bodeul_background</item>
    </style>

    <style name="BodeulHomeButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">12dp</item>
        <item name="android:minHeight">58dp</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="backgroundTint">@color/bodeul_primary</item>
        <item name="cornerRadius">28dp</item>
        <item name="elevation">3dp</item>
    </style>

    <style name="BodeulOutlinedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/bodeul_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="backgroundTint">@color/white</item>
        <item name="strokeColor">@color/bodeul_outline</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">24dp</item>
    </style>

    <style name="BodeulFilledInput" parent="Widget.MaterialComponents.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/bodeul_surface_alt</item>
        <item name="boxCornerRadiusBottomEnd">28dp</item>
        <item name="boxCornerRadiusBottomStart">28dp</item>
        <item name="boxCornerRadiusTopEnd">28dp</item>
        <item name="boxCornerRadiusTopStart">28dp</item>
        <item name="hintTextColor">@color/bodeul_text_secondary</item>
        <item name="boxStrokeColor">@color/bodeul_outline</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>
        <item name="helperTextTextColor">@color/bodeul_text_secondary</item>
        <item name="errorTextColor">@color/bodeul_primary_dark</item>
    </style>
</resources>
