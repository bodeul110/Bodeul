<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_surface_pill"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/textManagerInfoLineLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/bodeul_text_secondary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textManagerInfoLineValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:lineSpacingExtra="3dp"
        android:textColor="@color/bodeul_text_primary"
        android:textSize="14sp" />
</LinearLayout>

