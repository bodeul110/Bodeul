<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_glow"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="94dp"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:contentDescription="@string/app_name"
                android:src="@drawable/bodeul_logo_full" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/buttonBackBookingFollowUp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_pill"
                android:paddingStart="14dp"
                android:paddingTop="9dp"
                android:paddingEnd="14dp"
                android:paddingBottom="9dp"
                android:text="@string/guide_back"
                android:textColor="@color/bodeul_primary"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/textBookingFollowUpMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_surface_pill"
            android:paddingStart="14dp"
            android:paddingTop="8dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp"
            android:textColor="@color/bodeul_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/booking_follow_up_title"
            android:textColor="@color/bodeul_text_primary"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="4dp"
            android:text="@string/booking_follow_up_subtitle"
            android:textColor="@color/bodeul_text_secondary"
            android:textSize="14sp" />

        <include
            android:id="@+id/bookingFollowUpStatePanel"
            layout="@layout/include_state_panel" />

        <LinearLayout
            android:id="@+id/bookingFollowUpContentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@color/bodeul_surface"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp"
                app:strokeColor="@color/bodeul_outline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_primary_hero"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:id="@+id/textBookingFollowUpHeroBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_surface_pill"
                        android:paddingStart="12dp"
                        android:paddingTop="7dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="7dp"
                        android:textColor="@color/bodeul_text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textBookingFollowUpHeroTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:textColor="@color/white"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textBookingFollowUpHeroBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:lineSpacingExtra="4dp"
                        android:textColor="@color/white"
                        android:textSize="15sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/bodeul_surface"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp"
                app:strokeColor="@color/bodeul_outline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:id="@+id/textBookingFollowUpReviewTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/bodeul_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textBookingFollowUpReviewBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:lineSpacingExtra="4dp"
                        android:textColor="@color/bodeul_text_secondary"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:id="@+id/layoutBookingFollowUpReviewOptionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical" />

                    <TextView
                        android:id="@+id/textBookingFollowUpReviewSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_surface_pill"
                        android:lineSpacingExtra="4dp"
                        android:padding="16dp"
                        android:textColor="@color/bodeul_text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/textBookingFollowUpReviewSavedState"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textColor="@color/bodeul_text_secondary"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonBookingFollowUpReviewSave"
                        style="@style/BodeulHomeButton"
                        android:layout_marginTop="14dp"
                        android:text="@string/booking_follow_up_review_action_save" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/bodeul_surface"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp"
                app:strokeColor="@color/bodeul_outline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/booking_follow_up_settlement_title"
                        android:textColor="@color/bodeul_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:lineSpacingExtra="4dp"
                        android:text="@string/booking_follow_up_settlement_body"
                        android:textColor="@color/bodeul_text_secondary"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:id="@+id/layoutBookingFollowUpSettlementContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical" />

                    <TextView
                        android:id="@+id/textBookingFollowUpSettlementSavedState"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textColor="@color/bodeul_text_secondary"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonBookingFollowUpSettlementConfirm"
                        style="@style/BodeulHomeButton"
                        android:layout_marginTop="14dp"
                        android:text="@string/booking_follow_up_settlement_action_confirm" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonBookingFollowUpSettlementHelp"
                        style="@style/BodeulOutlinedButton"
                        android:layout_marginTop="10dp"
                        android:text="@string/booking_follow_up_settlement_action_help" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/bodeul_surface"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp"
                app:strokeColor="@color/bodeul_outline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:id="@+id/textBookingFollowUpEmergencyTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/bodeul_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textBookingFollowUpEmergencyBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:lineSpacingExtra="4dp"
                        android:textColor="@color/bodeul_text_secondary"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:id="@+id/layoutBookingFollowUpEmergencyContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical" />

                    <TextView
                        android:id="@+id/textBookingFollowUpEmergencySavedState"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textColor="@color/bodeul_text_secondary"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonBookingFollowUpCallManager"
                        style="@style/BodeulOutlinedButton"
                        android:layout_marginTop="16dp"
                        android:text="@string/booking_follow_up_action_call_manager" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonBookingFollowUpEmergencyDial"
                        style="@style/BodeulHomeButton"
                        android:layout_marginTop="10dp"
                        android:text="@string/booking_follow_up_action_call_119" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonBookingFollowUpEmergencyGuide"
                        style="@style/BodeulOutlinedButton"
                        android:layout_marginTop="10dp"
                        android:text="@string/booking_follow_up_action_open_guide" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonBookingFollowUpDetail"
                style="@style/BodeulOutlinedButton"
                android:layout_marginTop="20dp"
                android:text="@string/booking_follow_up_action_open_detail" />

            <ProgressBar
                android:id="@+id/progressBookingFollowUp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="14dp"
                android:visibility="gone"
                app:indicatorColor="@color/bodeul_primary" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
