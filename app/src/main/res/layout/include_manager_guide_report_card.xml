<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="14dp"
    app:cardBackgroundColor="@color/bodeul_surface"
    app:cardCornerRadius="28dp"
    app:cardElevation="6dp"
    app:strokeColor="@color/bodeul_outline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/guide_report_section"
                android:textColor="@color/bodeul_text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_blue"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:text="@string/guide_report_hint_label"
                android:textColor="@color/bodeul_primary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/textGuideVoiceDraftHelper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/guide_voice_draft_helper"
            android:textColor="@color/bodeul_text_secondary"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonFillVoiceReportDraft"
            style="@style/BodeulOutlinedButton"
            android:layout_marginTop="10dp"
            android:text="@string/guide_voice_draft_button" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/BodeulFilledInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:hint="@string/guide_report_summary_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputReportSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="3" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/BodeulFilledInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/guide_report_treatment_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputReportTreatment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="3" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/BodeulFilledInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/guide_report_medication_name_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputReportMedicationName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/guide_report_medication_comparison_label"
            android:textColor="@color/bodeul_text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/groupReportMedicationComparisonDecision"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/radioMedicationComparisonMatched"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/guide_report_medication_comparison_matched" />

            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/radioMedicationComparisonChanged"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/guide_report_medication_comparison_changed" />

            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/radioMedicationComparisonRecheck"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/guide_report_medication_comparison_recheck" />
        </RadioGroup>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/BodeulFilledInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/guide_report_medication_comparison_note_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputReportMedicationComparisonNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/BodeulFilledInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/guide_report_medication_change_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputReportMedicationChangeSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/BodeulFilledInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/guide_report_medication_schedule_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputReportMedicationScheduleNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/BodeulFilledInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/guide_report_next_visit_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputNextVisit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSubmitReport"
            style="@style/BodeulHomeButton"
            android:layout_marginTop="16dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
