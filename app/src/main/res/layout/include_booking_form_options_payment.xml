<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:text="@string/booking_option_section"
        android:textColor="@color/bodeul_text_primary"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/booking_option_helper"
        android:textColor="@color/bodeul_text_secondary"
        android:textSize="13sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/booking_trip_section"
        android:textColor="@color/bodeul_text_primary"
        android:textSize="13sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonBookingTripOneWay"
            style="@style/BodeulOutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:minHeight="44dp"
            android:text="@string/booking_trip_one_way"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonBookingTripRoundTrip"
            style="@style/BodeulOutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:minHeight="44dp"
            android:text="@string/booking_trip_round_trip"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/booking_manager_gender_section"
        android:textColor="@color/bodeul_text_primary"
        android:textSize="13sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonBookingManagerGenderAny"
            style="@style/BodeulOutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:minHeight="44dp"
            android:text="@string/booking_manager_gender_any"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonBookingManagerGenderFemale"
            style="@style/BodeulOutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            android:layout_weight="1"
            android:minHeight="44dp"
            android:text="@string/booking_manager_gender_female"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonBookingManagerGenderMale"
            style="@style/BodeulOutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:minHeight="44dp"
            android:text="@string/booking_manager_gender_male"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:text="@string/booking_payment_section"
        android:textColor="@color/bodeul_text_primary"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/booking_payment_section_helper"
        android:textColor="@color/bodeul_text_secondary"
        android:textSize="13sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/booking_payment_method_section"
        android:textColor="@color/bodeul_text_primary"
        android:textSize="13sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonBookingPaymentCard"
            style="@style/BodeulOutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:minHeight="44dp"
            android:text="@string/booking_payment_card"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonBookingPaymentEasyPay"
            style="@style/BodeulOutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            android:layout_weight="1"
            android:minHeight="44dp"
            android:text="@string/booking_payment_easy_pay"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonBookingPaymentOnSite"
            style="@style/BodeulOutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:minHeight="44dp"
            android:text="@string/booking_payment_on_site"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/booking_coupon_section"
        android:textColor="@color/bodeul_text_primary"
        android:textSize="13sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonBookingCouponNone"
            style="@style/BodeulOutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:minHeight="44dp"
            android:text="@string/booking_coupon_none"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonBookingCouponFirstVisit"
            style="@style/BodeulOutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            android:layout_weight="1"
            android:minHeight="44dp"
            android:text="@string/booking_coupon_first_visit"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonBookingCouponFamily"
            style="@style/BodeulOutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:minHeight="44dp"
            android:text="@string/booking_coupon_family"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_surface_pill"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/booking_price_section"
            android:textColor="@color/bodeul_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textBookingEstimateBase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/bodeul_text_primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/textBookingEstimateOption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/bodeul_text_primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/textBookingEstimateDiscount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/bodeul_text_primary"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="@color/bodeul_outline" />

        <TextView
            android:id="@+id/textBookingEstimateFinal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/bodeul_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textBookingPaymentHelper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/bodeul_text_secondary"
            android:textSize="13sp" />
    </LinearLayout>
</merge>
