<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:text="@string/booking_health_section"
        android:textColor="@color/bodeul_text_primary"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/booking_health_helper"
        android:textColor="@color/bodeul_text_secondary"
        android:textSize="13sp" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutBookingHealthSummary"
        style="@style/BodeulFilledInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:hint="@string/booking_health_summary_hint">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/inputBookingHealthSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="3" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutBookingMedicationSummary"
        style="@style/BodeulFilledInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="@string/booking_medication_summary_hint">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/inputBookingMedicationSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="2" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/booking_mobility_section"
        android:textColor="@color/bodeul_text_primary"
        android:textSize="13sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonBookingMobilityIndependent"
            style="@style/BodeulOutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:minHeight="44dp"
            android:text="@string/booking_mobility_independent"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonBookingMobilityWalkingAid"
            style="@style/BodeulOutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            android:layout_weight="1"
            android:minHeight="44dp"
            android:text="@string/booking_mobility_walking_aid"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonBookingMobilityWheelchair"
            style="@style/BodeulOutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:minHeight="44dp"
            android:text="@string/booking_mobility_wheelchair"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/textBookingLinkedSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:text="@string/booking_linked_section_default"
        android:textColor="@color/bodeul_text_primary"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textBookingLinkedHelper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:lineSpacingExtra="4dp"
        android:text="@string/booking_linked_helper_default"
        android:textColor="@color/bodeul_text_secondary"
        android:textSize="13sp" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutBookingLinkedName"
        style="@style/BodeulFilledInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:hint="@string/booking_linked_name_hint_default">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/inputBookingLinkedName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPersonName" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutBookingLinkedPhone"
        style="@style/BodeulFilledInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="@string/booking_linked_phone_hint_default">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/inputBookingLinkedPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="phone" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutBookingLinkedEmail"
        style="@style/BodeulFilledInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="@string/booking_linked_email_hint_default">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/inputBookingLinkedEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textEmailAddress" />
    </com.google.android.material.textfield.TextInputLayout>
</merge>
