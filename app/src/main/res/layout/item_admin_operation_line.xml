<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_surface_pill"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingTop="12dp"
    android:paddingEnd="16dp"
    android:paddingBottom="12dp">

    <TextView
        android:id="@+id/textAdminOperationLineLabel"
        android:layout_width="96dp"
        android:layout_height="wrap_content"
        android:textColor="@color/bodeul_text_secondary"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/textAdminOperationLineValue"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/bodeul_text_primary"
        android:textSize="14sp" />
</LinearLayout>
