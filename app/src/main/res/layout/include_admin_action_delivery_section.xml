<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="@string/admin_action_delivery_title"
        android:textColor="@color/bodeul_text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/admin_action_delivery_helper"
        android:textColor="@color/bodeul_text_secondary"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/textAdminActionDeliverySummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_surface_pill"
        android:lineSpacingExtra="4dp"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp"
        android:textColor="@color/bodeul_text_primary"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/adminActionDeliveryContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="vertical" />
</merge>
