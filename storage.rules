rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserExists() {
      return signedIn()
          && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function currentRole() {
      return currentUserExists()
          ? firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
          : null;
    }

    function isAdmin() {
      return currentRole() == 'ADMIN';
    }

    function isManager() {
      return currentRole() == 'MANAGER';
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function appointmentExists(appointmentRequestId) {
      return firestore.exists(
          /databases/(default)/documents/appointmentRequests/$(appointmentRequestId)
      );
    }

    function appointmentDoc(appointmentRequestId) {
      return firestore.get(
          /databases/(default)/documents/appointmentRequests/$(appointmentRequestId)
      );
    }

    function isAppointmentParticipant(appointmentRequestId) {
      return signedIn()
          && appointmentExists(appointmentRequestId)
          && (
            isAdmin()
            || appointmentDoc(appointmentRequestId).data.patientUserId == request.auth.uid
            || appointmentDoc(appointmentRequestId).data.guardianUserId == request.auth.uid
            || appointmentDoc(appointmentRequestId).data.managerUserId == request.auth.uid
          );
    }

    function sessionExists(sessionId) {
      return firestore.exists(/databases/(default)/documents/companionSessions/$(sessionId));
    }

    function sessionDoc(sessionId) {
      return firestore.get(/databases/(default)/documents/companionSessions/$(sessionId));
    }

    function isSessionParticipant(sessionId) {
      return signedIn()
          && sessionExists(sessionId)
          && (
            isAdmin()
            || sessionDoc(sessionId).data.managerUserId == request.auth.uid
            || isAppointmentParticipant(sessionDoc(sessionId).data.appointmentRequestId)
          );
    }

    function isAllowedDocumentKey(documentKey) {
      return documentKey == 'idCard'
          || documentKey == 'license'
          || documentKey == 'healthCertificate'
          || documentKey == 'criminalRecord';
    }

    function isAllowedDocumentContentType() {
      return request.resource != null
          && request.resource.contentType is string
          && (
            request.resource.contentType == 'application/pdf'
            || request.resource.contentType.matches('image/.*')
          );
    }

    function isAllowedDocumentSize() {
      return request.resource != null
          && request.resource.size is int
          && request.resource.size <= 10485760;
    }

    function isAllowedChatAttachmentContentType() {
      return request.resource != null
          && request.resource.contentType is string
          && (
            request.resource.contentType == 'application/pdf'
            || request.resource.contentType.matches('image/.*')
          );
    }

    function isAllowedChatAttachmentSize() {
      return request.resource != null
          && request.resource.size is int
          && request.resource.size <= 10485760;
    }

    match /manager-documents/{managerUserId}/{documentKey}/{fileName} {
      allow read: if isAdmin() || (isManager() && isSelf(managerUserId));
      allow write: if isManager()
          && isSelf(managerUserId)
          && isAllowedDocumentKey(documentKey)
          && isAllowedDocumentContentType()
          && isAllowedDocumentSize();
    }

    match /companion-chat-attachments/{sessionId}/{fileName} {
      allow read: if isSessionParticipant(sessionId);
      allow write: if isSessionParticipant(sessionId)
          && isAllowedChatAttachmentContentType()
          && isAllowedChatAttachmentSize();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
